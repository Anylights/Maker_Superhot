{
  "$schema": "../schemas/settings.schema.json",
  "sources": {
    "engine": {
      "tag": "stable"
    },
    "engine-res": {
      "tag": "stable"
    },
    "official-res": {
      "tag": "stable"
    }
  },
  "build": {
    "generate_fs_path": true,
    "output_dir": "../dist",
    "asset_dirs": [
      "../assets",
      "../scripts"
    ],
    "asset_ignores": []
  },
  "@runtime": {
    "multiplayer": {
      "enabled": true,
      "max_players": 16,
      "background_match": false,
      "persistent_world": {
        "enabled": true
      }
    }
  }
}