{
  "$schema": "../schemas/settings.schema.json",
  "sources": {
    "engine": {
      "tag": "stable"
    },
    "engine-res": {
      "tag": "stable"
    },
    "official-res": {
      "tag": "stable"
    }
  },
  "build": {
    "generate_fs_path": true,
    "output_dir": "../dist",
    "asset_dirs": [
      "../assets",
      "../scripts"
    ],
    "asset_ignores": []
  },
  "@runtime": {
    "multiplayer": {
      "enabled": true,
      "max_players": 4,
      "match_info": {
        "desc_name": "free_match_with_ai",
        "match_timeout": 10,
        "player_number": 4
      },
      "background_match": true
    }
  }
}